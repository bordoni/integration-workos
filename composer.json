{
	"name": "liquidweb/workos-identity",
	"description": "Enterprise identity management for WordPress powered by WorkOS.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "LiquidWeb Software",
			"homepage": "https://software.liquidweb.com"
		}
	],
	"require": {
		"php": ">=7.4",
		"lucatume/di52": "^4.0",
		"stellarwp/container-contract": "^1.1"
	},
	"require-dev": {
		"brianhenryie/strauss": "^0.19.2",
		"codeception/module-asserts": "^3.0",
		"codeception/module-cli": "^2.0",
		"codeception/module-db": "^3.0",
		"codeception/module-filesystem": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"lucatume/wp-browser": "^4.5",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"squizlabs/php_codesniffer": "^3.8",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"WorkOS\\": "src/WorkOS/"
		},
		"files": ["vendor/prefixed/autoload.php"]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	},
	"scripts": {
		"test:wpunit": "vendor/bin/codecept run wpunit",
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"strauss-install": [
			"test -f ./bin/strauss.phar || curl -o bin/strauss.phar -L -C - https://github.com/BrianHenryIE/strauss/releases/download/0.24.1/strauss.phar"
		],
		"strauss": [
			"@strauss-install",
			"@php bin/strauss.phar",
			"@composer dump-autoload"
		],
		"post-install-cmd": ["@strauss"],
		"post-update-cmd": ["@strauss"]
	},
	"extra": {
		"strauss": {
			"target_directory": "vendor/prefixed",
			"classmap_prefix": "WorkOS_",
			"constant_prefix": "WORKOS_VENDOR_",
			"namespace_prefix": "WorkOS\\Vendor\\",
			"packages": [
				"lucatume/di52",
				"stellarwp/container-contract"
			],
			"exclude_from_copy": {
				"file_patterns": [
					"/^tests\\//", "/^test\\//", "/^Test\\//",
					"/^examples\\//", "/^docs\\//", "/^bin\\//",
					"/\\.md$/", "/^phpunit/", "/^phpcs/",
					"/^\\.git/", "/^Makefile/"
				]
			},
			"delete_vendor_packages": true
		}
	}
}
